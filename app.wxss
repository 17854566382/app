page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: #f5f5f5;
}

.container {
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B00 0%, #FF8C3A 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary::after {
  border: none;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: #FF6B00;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.price {
  color: #FF6B00;
  font-weight: 600;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  background: rgba(255, 107, 0, 0.1);
  color: #FF6B00;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
}
