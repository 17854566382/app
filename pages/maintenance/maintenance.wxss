/* pages/maintenance/maintenance.wxss */
.container {
  padding: 24rpx;
  padding-bottom: 200rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 表单区块 */
.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #FF6B00;
  display: flex;
  align-items: center;
}

.selected-type {
  font-size: 26rpx;
  font-weight: normal;
  color: #FF6B00;
  margin-left: 16rpx;
}

.optional {
  font-size: 24rpx;
  color: #999;
  font-weight: 400;
  margin-left: 12rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.required {
  color: #FF6B00;
  margin-right: 4rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.value-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.textarea {
  width: 100%;
  height: 160rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
}

.picker .placeholder {
  color: #999;
}

.picker-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 服务类型网格 */
.service-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.service-item {
  width: calc(50% - 10rpx);
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 3rpx solid transparent;
  transition: all 0.2s;
  position: relative;
}

.service-item.active {
  background: #FFF7F0;
  border-color: #FF6B00;
  position: relative;
}

.check-icon {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background: #FF6B00;
  color: #fff;
  font-size: 24rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.service-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.service-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.service-desc {
  font-size: 22rpx;
  color: #999;
  text-align: center;
}

/* 门店信息 */
.store-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.store-card {
  background: #FFF7F0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.store-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.store-row:first-child {
  border-bottom: 1rpx solid #FFE8D6;
}

.store-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.store-text {
  flex: 1;
  font-size: 26rpx;
  color: #666;
}

.store-arrow {
  color: #FF6B00;
  font-size: 28rpx;
}

.store-phone-btn {
  color: #fff;
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  background: #FF6B00;
  border-radius: 24rpx;
}

/* 提交区域 */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.08);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FF6B00 0%, #FF8533 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.submit-btn.disabled {
  background: #ccc;
}

.submit-tip {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}
