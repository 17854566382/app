/* pages/user/user.wxss */
.user-header {
  background: linear-gradient(135deg, #FF6B00 0%, #FF8C3A 100%);
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  width: 100%;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-meta {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.phone {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.btn-login {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  margin: 20rpx 0 0 0;
  width: 100%;
}

.btn-login::after {
  border: none;
}

.btn-phone {
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  margin: 10rpx 0 0 0;
}

.btn-phone::after {
  border: none;
}

.vip-card {
  margin: -40rpx 30rpx 30rpx;
  background: linear-gradient(135deg, #1a1a1a 0%, #333 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  position: relative;
  z-index: 1;
}

.vip-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.vip-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFD700;
}

.vip-level {
  font-size: 24rpx;
  color: #FFD700;
  background: rgba(255, 215, 0, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.vip-content {
  display: flex;
  justify-content: space-around;
}

.vip-item {
  text-align: center;
}

.vip-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.vip-label {
  font-size: 24rpx;
  color: #999;
}

/* 管理员区域 */
.admin-section {
  margin: 20rpx 30rpx;
}

.section-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.admin-menu {
  background: #FFF7F0;
  border: 2rpx solid #FFE8D6;
}

.admin-menu .menu-item {
  border-bottom-color: #FFE8D6;
}

.admin-menu .menu-item:last-child {
  border-bottom: none;
}

.menu-list {
  background: #fff;
  margin: 0 30rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.btn-logout {
  background: #fff;
  color: #ff4d4f;
  padding: 24rpx 0;
  border-radius: 20rpx;
  font-size: 30rpx;
  border: 2rpx solid #ff4d4f;
  margin: 40rpx 30rpx;
  width: calc(100% - 60rpx);
}

.btn-logout::after {
  border: none;
}

.version-info {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 30rpx 0 50rpx;
}
