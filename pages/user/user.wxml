<!--pages/user/user.wxml-->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-header">
    <view class="user-info">
      <image class="avatar" src="{{userInfo ? userInfo.avatarUrl || '/images/avatar-default.png' : '/images/avatar-default.png'}}"/>
      <view class="user-meta">
        <text class="nickname">{{userInfo ? userInfo.nickName || '微信用户' : '未登录'}}</text>
        <text class="phone">{{userInfo && userInfo.phone ? userInfo.phone : ''}}</text>
      </view>
    </view>
    
    <!-- 未登录：显示微信登录按钮 -->
    <button wx:if="{{!isLogin}}" class="btn-login" bindtap="handleLogin" loading="{{loading}}">
      微信一键登录
    </button>
    
    <!-- 已登录但未绑定手机：显示手机号授权按钮 -->
    <button wx:if="{{isLogin && !userInfo.phone}}" class="btn-phone" open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber">
      绑定手机号
    </button>
  </view>

  <!-- 会员卡片 -->
  <view class="vip-card" wx:if="{{memberInfo}}">
    <view class="vip-header">
      <text class="vip-title">海宝会员</text>
      <text class="vip-level">{{memberInfo.level}}</text>
    </view>
    <view class="vip-content">
      <view class="vip-item">
        <text class="vip-value">¥{{memberInfo.balance}}</text>
        <text class="vip-label">余额</text>
      </view>
      <view class="vip-item">
        <text class="vip-value">{{memberInfo.points}}</text>
        <text class="vip-label">积分</text>
      </view>
      <view class="vip-item">
        <text class="vip-value">{{memberInfo.coupons}}</text>
        <text class="vip-label">优惠券</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goToOrders">
      <text class="menu-icon">📋</text>
      <text class="menu-text">我的订单</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToMemberCard">
      <text class="menu-icon">💳</text>
      <text class="menu-text">会员卡</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="callPhone">
      <text class="menu-icon">📞</text>
      <text class="menu-text">联系电话</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToStore">
      <text class="menu-icon">📍</text>
      <text class="menu-text">门店导航</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onShareAppMessage">
      <text class="menu-icon">🔗</text>
      <text class="menu-text">分享给好友</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">></text>
    </view>
    <!-- wx:if="{{isAdmin}}" -->
    <view class="menu-item" bindtap="goToAdmin">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">商品管理</text>
      <text class="menu-arrow">></text>
    </view>
  </view>
  
  <!-- 退出登录按钮 -->
  <button wx:if="{{isLogin}}" class="btn-logout" bindtap="handleLogout">
    退出登录
  </button>
  
  <!-- 版本号 -->
  <view class="version-info">v{{version}}</view>
</view>
