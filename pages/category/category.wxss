/* pages/category/category.wxss */
/* 注意：gap 属性在旧版微信不支持，用 margin 替代 */
.search-bar {
  padding: 20rpx;
  background: #fff;
}

.search-input {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 30rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: #999;
}

.search-input input {
  flex: 1;
  font-size: 28rpx;
}

/* 分类筛选栏 */
.filter-bar {
  background: #fff;
  padding: 20rpx 0;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.filter-tabs {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 0 20rpx;
}

.filter-tab {
  position: relative;
  padding: 16rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 400;
  transition: all 0.25s ease;
}

.filter-tab.active .tab-text {
  color: #FF6B00;
  font-weight: 600;
  font-size: 32rpx;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #FF6B00 0%, #FF8C3A 100%);
  border-radius: 3rpx;
}

.product-scroll {
  height: calc(100vh - 200rpx);
  /* 兼容旧版微信 */
  height: -webkit-calc(100vh - 200rpx);
  height: 100vh;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
}

/* 用固定宽度替代 fr 单位，兼容旧版 */
.product-card {
  width: calc(50% - 10rpx);
  margin-right: 20rpx;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
}

.product-card:nth-child(2n) {
  margin-right: 0;
}

.product-image-wrap {
  position: relative;
  height: 320rpx;
}

.product-image {
  width: 100%;
  height: 100%;
}

.tag-wrap {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  display: flex;
}

.product-tag {
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  margin-right: 8rpx;
}

.product-content {
  padding: 20rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-spec {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.color-dots {
  display: flex;
  margin-bottom: 16rpx;
}

.color-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  margin-right: 12rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price-wrap {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #FF6B00;
}

.price-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF6B00;
}

.btn-buy {
  background: linear-gradient(135deg, #FF6B00 0%, #FF8C3A 100%);
  color: #fff;
  border-radius: 30rpx;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  margin: 0;
  line-height: 1.5;
}

.btn-buy::after {
  border: none;
}
