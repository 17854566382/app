/* pages/admin-maintenance/admin-maintenance.wxss */
.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

/* 统计栏 */
.stats-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FF6B00;
  line-height: 1.3;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  white-space: nowrap;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.filter-item {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 32rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
  margin-right: 16rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.filter-item:last-child {
  margin-right: 0;
}

.filter-item.active {
  background: #FF6B00;
  color: #fff;
}

/* 列表区域 */
.list-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.export-btn {
  font-size: 26rpx;
  color: #FF6B00;
}

/* 加载中 */
.loading-wrap {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

/* 预约卡片 */
.appointment-list {
  overflow: hidden;
}

.appointment-card {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.appointment-card:last-child {
  margin-bottom: 0;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.user-phone {
  font-size: 26rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.status-tag.status-pending {
  background: #FFF7E6;
  color: #FA8C16;
}

.status-tag.status-confirmed {
  background: #E6F7FF;
  color: #1890FF;
}

.status-tag.status-completed {
  background: #F6FFED;
  color: #52C41A;
}

.status-tag.status-cancelled {
  background: #FFF1F0;
  color: #F5222D;
}

.card-body {
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.info-text {
  font-size: 28rpx;
  color: #666;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #eee;
}

.create-time {
  font-size: 24rpx;
  color: #999;
}

.view-detail {
  font-size: 26rpx;
  color: #FF6B00;
}

/* ========== 详情弹窗 ========== */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
}

.detail-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.detail-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 85vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.detail-scroll {
  flex: 1;
  height: 0;
  overflow: hidden;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.close-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
}

.close-icon {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.detail-body {
  padding: 24rpx 32rpx;
  padding-bottom: 32rpx;
}

.detail-group {
  margin-bottom: 32rpx;
}

.detail-group:last-child {
  margin-bottom: 0;
}

.group-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #FF6B00;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
  width: 140rpx;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  text-align: right;
  word-break: break-all;
  margin-left: 16rpx;
}

.detail-value.phone-link {
  color: #1890FF;
}

.status-badge {
  display: inline-block;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
}

.status-badge.status-pending {
  background: #FFF7E6;
  color: #FA8C16;
}

.status-badge.status-confirmed {
  background: #E6F7FF;
  color: #1890FF;
}

.status-badge.status-completed {
  background: #F6FFED;
  color: #52C41A;
}

.status-badge.status-cancelled {
  background: #FFF1F0;
  color: #F5222D;
}

.detail-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.action-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin: 0;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: #FF6B00;
  color: #fff;
}

.action-btn.secondary {
  background: #fff;
  color: #FF6B00;
  border: 2rpx solid #FF6B00;
  box-sizing: border-box;
}

.btn-icon {
  margin-right: 8rpx;
}

.status-row {
  display: flex;
  gap: 16rpx;
}

.status-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin: 0;
}

.status-btn::after {
  border: none;
}

.status-btn.confirm {
  background: #1890FF;
  color: #fff;
}

.status-btn.complete {
  background: #52C41A;
  color: #fff;
}

.status-btn.cancel {
  background: #fff;
  color: #F5222D;
  border: 2rpx solid #F5222D;
  box-sizing: border-box;
}

/* ========== 短信弹窗 ========== */
.sms-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1100;
}

.sms-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.sms-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
}

.sms-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.sms-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.sms-body {
  padding: 24rpx 32rpx;
}

.sms-to {
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.sms-label {
  font-size: 28rpx;
  color: #999;
}

.sms-phone {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.sms-input {
  width: 100%;
  min-height: 200rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

.sms-count-row {
  text-align: right;
  margin-top: 12rpx;
}

.sms-count {
  font-size: 24rpx;
  color: #999;
}

.sms-actions {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.sms-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin: 0;
}

.sms-btn::after {
  border: none;
}

.sms-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.sms-btn.send {
  background: #FF6B00;
  color: #fff;
}
