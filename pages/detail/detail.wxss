/* pages/detail/detail.wxss */
.container {
  padding-bottom: 0;
}

.bottom-space {
  height: 160rpx;
}

.image-section {
  position: relative;
  height: 600rpx;
}

.product-swiper {
  height: 100%;
}

.product-image {
  width: 100%;
  height: 100%;
}

.image-count {
  position: absolute;
  right: 30rpx;
  bottom: 30rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.image-counter {
  position: absolute;
  right: 30rpx;
  bottom: 30rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.info-section {
  margin-top: -40rpx;
  position: relative;
  z-index: 1;
  border-radius: 24rpx 24rpx 0 0;
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.price-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.price {
  margin-right: 20rpx;
}

.price {
  font-size: 48rpx;
  font-weight: 700;
  color: #FF6B00;
}

.original-price {
  font-size: 28rpx;
  color: #999;
  text-decoration: line-through;
}

.tag {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag.hot {
  background: linear-gradient(135deg, #FF6B00 0%, #FF8C3A 100%);
  color: #fff;
}

.product-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.product-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.section {
  margin-top: 20rpx;
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: #FF6B00;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.color-list {
  display: flex;
  flex-wrap: wrap;
}

.color-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
  margin-right: 20rpx;
  margin-bottom: 16rpx;
}

.color-item.active {
  background: rgba(255, 107, 0, 0.1);
  border-color: #FF6B00;
}

.color-swatch {
  width: 40rpx;
  height: 44rpx;
  border-radius: 50%;
  margin-right: 14rpx;
  border: 2rpx solid rgba(0,0,0,0.15);
  flex-shrink: 0;
  transition: transform 0.2s;
}

.color-item.active .color-swatch {
  transform: scale(1.15);
  box-shadow: 0 0 0 4rpx rgba(255, 107, 0, 0.25);
}

.color-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  border: 2rpx solid #ddd;
}

.color-name {
  font-size: 28rpx;
  color: #333;
}

.color-check {
  margin-left: 12rpx;
  color: #FF6B00;
  font-weight: 600;
}

.selected-color-tip {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #999;
}

.tip-color {
  color: #FF6B00;
  font-weight: 600;
}

.config-list {
  display: flex;
  flex-direction: column;
}

.config-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  margin-bottom: 16rpx;
}

.config-item:last-child {
  margin-bottom: 0;
}

.config-item.active {
  background: rgba(255, 107, 0, 0.1);
  border-color: #FF6B00;
}

.config-info {
  flex: 1;
}

.config-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.config-desc {
  font-size: 24rpx;
  color: #999;
}

.config-price {
  font-size: 28rpx;
  color: #FF6B00;
  font-weight: 500;
  margin-right: 16rpx;
}

.config-check {
  color: #FF6B00;
  font-weight: 600;
}

.spec-grid {
  display: flex;
  flex-wrap: wrap;
}

.spec-item {
  width: calc(33.33% - 16rpx);
  text-align: center;
  padding: 24rpx 8rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-right: 24rpx;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.spec-item:nth-child(3n) {
  margin-right: 0;
}

.spec-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 12rpx;
}

.spec-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.spec-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.detail-list {
  display: flex;
  flex-direction: column;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #666;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
  box-sizing: border-box;
  gap: 20rpx;
}

.btn-secondary {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border: 2rpx solid #FF6B00;
  color: #FF6B00;
  padding: 20rpx 24rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
  margin: 0;
  line-height: 1.5;
}

.btn-secondary::after {
  border: none;
}

.btn-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.btn-submit {
  flex: 1;
  background: linear-gradient(135deg, #FF6B00 0%, #FF8C3A 100%);
  color: #fff;
  padding: 22rpx 40rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin: 0;
  line-height: 1.5;
}

.btn-submit::after {
  border: none;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.not-found {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.feature-list {
  display: flex;
  flex-wrap: wrap;
}

.feature-item {
  display: flex;
  align-items: center;
  width: 50%;
  margin-bottom: 16rpx;
}

.feature-icon {
  color: #52c41a;
  margin-right: 12rpx;
  font-weight: 600;
}

.feature-text {
  font-size: 28rpx;
  color: #333;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}
