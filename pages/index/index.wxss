/* pages/index/index.wxss */
.banner {
  height: 400rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.quick-entry {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 20rpx;
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.entry-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.iconfont {
  font-size: 48rpx;
}

.entry-text {
  font-size: 26rpx;
  color: #333;
}

.section {
  margin-top: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.more {
  font-size: 26rpx;
  color: #999;
}

.product-list {
  display: flex;
  flex-wrap: wrap;
}

.product-item {
  width: calc(50% - 15rpx);
  margin-right: 20rpx;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.product-item:nth-child(2n) {
  margin-right: 0;
}

.product-img {
  width: 100%;
  height: 280rpx;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.product-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price {
  font-size: 32rpx;
  color: #FF6B00;
  font-weight: 600;
}

.advantage-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 20rpx;
}

.advantage-item {
  width: calc(50% - 20rpx);
  text-align: center;
  padding: 30rpx 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  box-sizing: border-box;
  margin-bottom: 20px;
}

.advantage-item:nth-child(2n) {
  margin-left: 30rpx;
}

.advantage-icon {
  font-size: 60rpx;
  display: block;
  margin-bottom: 16rpx;
}

.advantage-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.advantage-desc {
  font-size: 24rpx;
  color: #999;
}
